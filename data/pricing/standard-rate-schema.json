{
  "schema_version": "2026-06-25",
  "description": "Unified pricing schema for the quote page. Channels remain independent while sharing one searchable structure.",
  "design_rules": [
    "Each rate row belongs to one independent channel.",
    "One row only describes one pricing rule or one lane price.",
    "Do not merge different suppliers into a single anonymous price row.",
    "Keep the original workbook source and sheet source for audit and weekly updates.",
    "Use the same core fields for FCL, DDP, FBA, and DG, then extend with service-specific fields."
  ],
  "entities": {
    "channel_master": {
      "purpose": "Defines the independent channels shown or hidden in the system.",
      "primary_key": "channel_id",
      "fields": [
        { "name": "channel_id", "type": "string", "required": true, "example": "YTHQ_US_SEA_DDP" },
        { "name": "channel_code", "type": "string", "required": true, "example": "YTHQ" },
        { "name": "supplier_name", "type": "string", "required": true, "example": "YTHQ Logistics" },
        { "name": "display_name", "type": "string", "required": true, "example": "US Sea DDP - Matson Fast" },
        { "name": "quote_page_group", "type": "enum", "required": true, "allowed": ["ocean_fcl", "ddp", "fba_delivery", "dangerous_goods", "sailing_schedule"] },
        { "name": "service_mode", "type": "enum", "required": true, "allowed": ["port_to_port", "door_to_door", "sea_ddp", "air_ddp", "rail_ddp", "road_ddp", "truck_ddp", "fba_sea", "fba_air", "fba_truck", "dg_ocean", "dg_air"] },
        { "name": "market_region", "type": "string", "required": true, "example": "USA" },
        { "name": "status", "type": "enum", "required": true, "allowed": ["active", "inactive", "manual_only"] },
        { "name": "supports_fba", "type": "boolean", "required": true, "example": true },
        { "name": "supports_dg", "type": "boolean", "required": true, "example": false },
        { "name": "pricing_unit", "type": "enum", "required": true, "allowed": ["per_container", "per_kg", "per_cbm", "per_ticket", "mixed"] },
        { "name": "currency", "type": "string", "required": true, "example": "USD" },
        { "name": "effective_date", "type": "date", "required": true, "example": "2026-06-25" },
        { "name": "expiry_date", "type": "date", "required": false, "example": "2026-07-01" },
        { "name": "source_file", "type": "string", "required": true, "example": "YTHQ 美国专线价格表.xlsx" },
        { "name": "source_sheet", "type": "string", "required": true, "example": "美国海运海派" },
        { "name": "notes", "type": "string", "required": false, "example": "Best for US West replenishment." }
      ]
    },
    "rate_card": {
      "purpose": "The main searchable pricing table. Each row is one lane price or one rule band under an independent channel.",
      "primary_key": "rate_id",
      "fields": [
        { "name": "rate_id", "type": "string", "required": true, "example": "rate_ythq_us_sea_ddp_001" },
        { "name": "channel_id", "type": "string", "required": true, "example": "YTHQ_US_SEA_DDP" },
        { "name": "quote_page_group", "type": "enum", "required": true, "allowed": ["ocean_fcl", "ddp", "fba_delivery", "dangerous_goods"] },
        { "name": "service_mode", "type": "enum", "required": true, "allowed": ["port_to_port", "door_to_door", "sea_ddp", "air_ddp", "rail_ddp", "road_ddp", "truck_ddp", "fba_sea", "fba_air", "fba_truck", "dg_ocean", "dg_air"] },
        { "name": "origin_country", "type": "string", "required": true, "example": "China" },
        { "name": "origin_city", "type": "string", "required": false, "example": "Shenzhen" },
        { "name": "origin_port", "type": "string", "required": false, "example": "Yantian" },
        { "name": "destination_country", "type": "string", "required": true, "example": "United States" },
        { "name": "destination_city", "type": "string", "required": false, "example": "Los Angeles" },
        { "name": "destination_port", "type": "string", "required": false, "example": "Los Angeles" },
        { "name": "destination_zip_zone", "type": "string", "required": false, "example": "90001-93599" },
        { "name": "destination_address_type", "type": "enum", "required": false, "allowed": ["port", "commercial", "residential", "amazon_fba", "warehouse"] },
        { "name": "amazon_market", "type": "string", "required": false, "example": "US" },
        { "name": "amazon_warehouse_code", "type": "string", "required": false, "example": "ONT8" },
        { "name": "amazon_warehouse_name", "type": "string", "required": false, "example": "ONT8 Amazon Fulfillment Center" },
        { "name": "cargo_type", "type": "string", "required": false, "example": "General cargo" },
        { "name": "cargo_category", "type": "enum", "required": false, "allowed": ["general", "battery", "oversized", "sensitive", "dangerous_goods"] },
        { "name": "dangerous_goods_class", "type": "string", "required": false, "example": "Class 9" },
        { "name": "un_number", "type": "string", "required": false, "example": "UN3481" },
        { "name": "container_type", "type": "enum", "required": false, "allowed": ["20GP", "40GP", "40HQ", "45HQ", "LCL"] },
        { "name": "billing_unit", "type": "enum", "required": true, "allowed": ["container", "kg", "cbm", "shipment", "tiered"] },
        { "name": "min_weight_kg", "type": "number", "required": false, "example": 12 },
        { "name": "max_weight_kg", "type": "number", "required": false, "example": 70 },
        { "name": "min_volume_cbm", "type": "number", "required": false, "example": 0.5 },
        { "name": "max_volume_cbm", "type": "number", "required": false, "example": 5 },
        { "name": "min_pieces", "type": "number", "required": false, "example": 1 },
        { "name": "max_pieces", "type": "number", "required": false, "example": 999 },
        { "name": "base_price", "type": "number", "required": true, "example": 3280 },
        { "name": "currency", "type": "string", "required": true, "example": "USD" },
        { "name": "price_unit_label", "type": "string", "required": true, "example": "USD / 40HQ" },
        { "name": "tax_included", "type": "boolean", "required": true, "example": false },
        { "name": "customs_included", "type": "boolean", "required": true, "example": false },
        { "name": "delivery_included", "type": "boolean", "required": true, "example": true },
        { "name": "fuel_surcharge", "type": "number", "required": false, "example": 0.3 },
        { "name": "remote_area_fee", "type": "number", "required": false, "example": 0.6 },
        { "name": "other_surcharge_name", "type": "string", "required": false, "example": "Peak Season" },
        { "name": "other_surcharge_amount", "type": "number", "required": false, "example": 120 },
        { "name": "transit_time_min_days", "type": "number", "required": false, "example": 18 },
        { "name": "transit_time_max_days", "type": "number", "required": false, "example": 22 },
        { "name": "schedule_label", "type": "string", "required": false, "example": "Weekly Friday departure" },
        { "name": "remarks", "type": "string", "required": false, "example": "Commercial address only." },
        { "name": "effective_date", "type": "date", "required": true, "example": "2026-06-25" },
        { "name": "expiry_date", "type": "date", "required": false, "example": "2026-07-01" },
        { "name": "source_file", "type": "string", "required": true, "example": "cargosoon 新 Peggy 美加整柜模版.xlsx" },
        { "name": "source_sheet", "type": "string", "required": true, "example": "海运价格导入模板" },
        { "name": "source_row_ref", "type": "string", "required": false, "example": "row_27" }
      ]
    },
    "schedule_card": {
      "purpose": "Independent schedule rows for the Sailing Schedule tab.",
      "primary_key": "schedule_id",
      "fields": [
        { "name": "schedule_id", "type": "string", "required": true, "example": "sch_rn_001" },
        { "name": "channel_id", "type": "string", "required": true, "example": "RN_US_SCHEDULE" },
        { "name": "route_name", "type": "string", "required": true, "example": "Yantian - Los Angeles" },
        { "name": "carrier_name", "type": "string", "required": false, "example": "Matson" },
        { "name": "vessel_voyage", "type": "string", "required": false, "example": "MATSONIA 065E" },
        { "name": "cutoff_date", "type": "string", "required": false, "example": "2026-06-27" },
        { "name": "etd", "type": "string", "required": false, "example": "2026-06-30" },
        { "name": "eta", "type": "string", "required": false, "example": "2026-07-13" },
        { "name": "status", "type": "enum", "required": true, "allowed": ["open", "nearly_full", "closed"] },
        { "name": "source_file", "type": "string", "required": true, "example": "RN 美国专线价格表.xlsx" },
        { "name": "source_sheet", "type": "string", "required": true, "example": "船期表" }
      ]
    }
  },
  "recommended_storage": {
    "channel_master_file": "data/pricing/channel-master.json",
    "rate_card_file": "data/pricing/rate-card.json",
    "schedule_card_file": "data/pricing/schedule-card.json"
  },
  "query_logic": {
    "quote_page_group_first": true,
    "channel_independence": "Always keep channel_id and channel_code in search results so each supplier lane remains independent.",
    "fcl_lookup": "Match by origin_port, destination_port, container_type, and effective_date.",
    "ddp_lookup": "Match by destination_country or destination_zip_zone, cargo category, billing tier, and effective_date.",
    "fba_lookup": "Match by amazon_market and amazon_warehouse_code first, fallback to destination address parsing.",
    "dangerous_goods_lookup": "Require cargo_category=dangerous_goods or explicit DG class / UN number before returning DG-only channels."
  },
  "result_mapping_for_quote_engine": {
    "supplierName": "supplier_name",
    "standardChannelName": "display_name",
    "routeType": "quote_page_group",
    "origin": "origin_port or origin_city",
    "destination": "destination_port or destination_city or amazon_warehouse_code",
    "currency": "currency",
    "basePrice": "base_price",
    "taxPrice": "derived from tax_included and tax components if separated",
    "remoteAreaFee": "remote_area_fee",
    "otherSurchargeLabel": "other_surcharge_name",
    "otherSurchargeAmount": "other_surcharge_amount",
    "transitDays": "transit_time_min_days + transit_time_max_days"
  },
  "sample_rows": {
    "channel_master": {
      "channel_id": "HMLX_US_FBA_SEA",
      "channel_code": "HMLX",
      "supplier_name": "HMLX Logistics",
      "display_name": "US FBA Sea Delivery",
      "quote_page_group": "fba_delivery",
      "service_mode": "fba_sea",
      "market_region": "USA",
      "status": "active",
      "supports_fba": true,
      "supports_dg": false,
      "pricing_unit": "mixed",
      "currency": "USD",
      "effective_date": "2026-06-25",
      "source_file": "HMLX 美国 加拿大 海派 海卡 FBA.xlsx",
      "source_sheet": "FBA仓库代码表"
    },
    "rate_card": {
      "rate_id": "rate_peggy_us_lax_40hq_001",
      "channel_id": "PEGGY_US_FCL",
      "quote_page_group": "ocean_fcl",
      "service_mode": "port_to_port",
      "origin_country": "China",
      "origin_port": "Yantian",
      "destination_country": "United States",
      "destination_port": "Los Angeles",
      "container_type": "40HQ",
