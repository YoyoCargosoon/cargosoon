      "transit_time_max_days": 20,
      "effective_date": "2026-06-25",
      "source_file": "cargosoon 新 Peggy 美加整柜模版.xlsx",
      "source_sheet": "海运价格导入模板"
    },
    "schedule_card": {
      "schedule_id": "sch_rn_matson_001",
      "channel_id": "RN_US_SCHEDULE",
      "route_name": "Shanghai - Los Angeles",
      "carrier_name": "Matson",
      "vessel_voyage": "MATSONIA 065E",
      "cutoff_date": "2026-06-27",
      "etd": "2026-06-30",
      "eta": "2026-07-13",
      "status": "open",
      "source_file": "RN 美国专线价格表.xlsx",
      "source_sheet": "船期表"
    }
  }
}
